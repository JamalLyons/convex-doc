{
	"name": "convexdoc",
	"version": "0.1.7",
	"description": "Documentation generator and interactive tester for Convex deployments",
	"author": {
		"name": "Jamal Lyons",
		"url": "https://www.jamallyons.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/jamallyons/convex-doc.git"
	},
	"homepage": "https://github.com/jamallyons/convex-doc#readme",
	"bugs": {
		"url": "https://github.com/jamallyons/convex-doc/issues"
	},
	"keywords": [
		"convex",
		"documentation",
		"api-docs",
		"cli",
		"developer-tools"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"license": "MIT",
	"type": "module",
	"bin": {
		"convexdoc": "./dist/main.js"
	},
	"main": "./dist/main.js",
	"types": "./dist/main.d.ts",
	"files": [
		"dist",
		"assets"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx lib/main.ts",
		"test": "tsx --test test/**/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"convex:dev": "pnpm dlx convex dev --once",
		"clean": "rm -rf dist docs",
		"prepublishOnly": "pnpm run clean && pnpm run build && pnpm test",
		"release": "pnpm run clean && pnpm run build && pnpm test && pnpm publish --access public"
	},
	"dependencies": {
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"convex": "^1.32.0",
		"execa": "^9.6.1",
		"marked": "^17.0.4",
		"ora": "^9.3.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@types/node": "^25.3.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsx": "^4.21.0"
	}
}